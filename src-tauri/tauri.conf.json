{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HAVEN Sovereign",
  "version": "5.0.0",
  "identifier": "sa.khawrizm.haven",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "set HAVEN_DESKTOP=1&& npm run dev",
    "beforeBuildCommand": "set HAVEN_DESKTOP=1&& npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HAVEN Sovereign",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
